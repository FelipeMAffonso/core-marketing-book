}
.title em {
  font-style: normal;
  color: var(--accent);
}
.rule {
  width: 60px;
  height: 2px;
  background: var(--accent);
  margin-top: 14px;
  margin-bottom: 18px;
}

.head { flex-shrink: 0; }

.body-area {
