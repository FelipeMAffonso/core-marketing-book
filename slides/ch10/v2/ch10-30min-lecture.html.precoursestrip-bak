  min-width: 220px;
  max-width: 320px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.slide.no-exhibit .body-text {
  flex: 1 1 auto;
}

.lede {
  font-size: 22px;
  line-height: 1.4;
  color: var(--ink-body);
  max-width: 720px;
}
.slide.with-exhibit .lede {
  font-size: 20px;
  line-height: 1.4;
}
.lede em { font-style: normal; color: var(--accent); }

.build {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 14px;
  max-width: 760px;
}
.build li {
  font-size: 20px;
  line-height: 1.4;
  color: var(--ink-body);
  padding-left: 28px;
  position: relative;
  opacity: 0.18;
  transition: opacity 220ms ease-out;
}
.build li::before {
  content: counter(rev, decimal);
  counter-increment: rev;
  position: absolute;
  left: 0;
  top: 4px;
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: var(--accent);
  color: #fff;
  font-size: 11px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}
.build { counter-reset: rev; }
.build li em { font-style: normal; color: var(--accent); }
.build li.shown { opacity: 1; }

.source {
  position: absolute;
  bottom: 14px;
  right: 20px;
  font-size: 11px;
  color: var(--source);
  letter-spacing: 0.02em;
  max-width: 700px;
  text-align: right;
}

