<script>
(function() {
  const slides = document.querySelectorAll('.slide');
  let cur = 0;
  function show(i) {
    slides.forEach((s, idx) => s.classList.toggle('current', idx === i));
    cur = i;
    location.hash = '#' + (i + 1);
    // reveal build_reveal frames
    const cur_s = slides[i];
    if (cur_s) {
      const frames = cur_s.querySelectorAll('.frame');
      frames.forEach((f, fi) => f.classList.toggle('shown', fi === 0));
      cur_s.dataset.frameIdx = '0';
    }
  }
  function advanceFrameOrSlide(dir) {
    const s = slides[cur];
    const frames = s ? s.querySelectorAll('.frame') : [];
    const idxAttr = parseInt((s && s.dataset.frameIdx) || '0', 10);
    if (dir > 0 && frames.length && idxAttr < frames.length - 1) {
      const ni = idxAttr + 1;
      s.dataset.frameIdx = String(ni);
      frames.forEach((f, fi) => f.classList.toggle('shown', fi <= ni));
      return;
    }
    if (dir < 0 && frames.length && idxAttr > 0) {
      const ni = idxAttr - 1;
      s.dataset.frameIdx = String(ni);
      frames.forEach((f, fi) => f.classList.toggle('shown', fi <= ni));
      return;
    }
    const next = Math.max(0, Math.min(slides.length - 1, cur + dir));
    show(next);
  }
  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowRight' || e.key === ' ' || e.key === 'PageDown' || e.key === 'j' || e.key === 'l') {
      advanceFrameOrSlide(1); e.preventDefault();
    } else if (e.key === 'ArrowLeft' || e.key === 'PageUp' || e.key === 'k' || e.key === 'h') {
      advanceFrameOrSlide(-1); e.preventDefault();
    } else if (e.key === 'Home') {
      show(0); e.preventDefault();
    } else if (e.key === 'End') {
      show(slides.length - 1); e.preventDefault();
    }
  });
  document.addEventListener('click', (e) => {
    if (e.target.closest('a, button, input, select, textarea')) return;
    const rect = document.documentElement.getBoundingClientRect();
    const x = (e.clientX - rect.left) / rect.width;
    if (x < 0.3) advanceFrameOrSlide(-1);
    else if (x > 0.7) advanceFrameOrSlide(1);
  });
  // initial slide from hash
  const hash = parseInt(location.hash.slice(1), 10);
  if (!isNaN(hash) && hash >= 1 && hash <= slides.length) {
    show(hash - 1);
  } else {
    show(0);
  }
})();
</script>

