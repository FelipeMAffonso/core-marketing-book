  width: 100vw;
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}
.slide {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(var(--scale, 1));
  width: 960px;
  height: 540px;
  background: var(--bg);
  padding: 28px 40px 48px 40px;
  overflow: hidden;
  box-shadow: 0 8px 32px -8px rgba(0,0,0,.35);
  display: none;
  flex-direction: column;
}
.slide.current { display: flex; }

@media (min-aspect-ratio: 16/9) {
  .slide { transform: translate(-50%, -50%) scale(calc((100vh - 48px) / 540)); }
}
@media (max-aspect-ratio: 16/9) {
  .slide { transform: translate(-50%, -50%) scale(calc((100vw - 48px) / 960)); }
}

.page {
  position: absolute;
  top: 22px;
  right: 40px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink-mute);
}
.eyebrow {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink-mute);
