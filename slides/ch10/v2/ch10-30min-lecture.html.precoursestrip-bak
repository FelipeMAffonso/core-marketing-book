}
.activity-prompts h4 {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--accent-deep);
  margin-bottom: 10px;
}
.activity-prompts ul {
  list-style: none;
  padding: 0;
}
.activity-prompts li {
  font-size: 18px;
  line-height: 1.4;
  color: var(--ink-body);
  padding-left: 18px;
  position: relative;
  margin-bottom: 6px;
}
.activity-prompts li::before {
  content: "";
  position: absolute;
  left: 0;
  top: 11px;
  width: 10px;
  height: 1px;
  background: var(--accent);
}

.exhibit.missing {
  background: var(--bg-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  font-style: italic;
  color: var(--ink-mute);
}

</style>
</head>
