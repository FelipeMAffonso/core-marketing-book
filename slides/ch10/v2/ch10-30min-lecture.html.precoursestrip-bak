.cover-stack { flex: 1; display: flex; flex-direction: column; justify-content: center; }
.cover-h1 {
  font-size: 54px;
  font-weight: 600;
  line-height: 1.08;
  letter-spacing: -0.02em;
  color: var(--ink);
  max-width: 17ch;
}
.cover-h1 em { font-style: italic; color: var(--accent); font-weight: 500; }
.cover-meta {
  font-size: 20px;
  color: var(--ink-soft);
  margin-top: 22px;
  max-width: 44ch;
  line-height: 1.5;
}
.cover-foot {
  display: flex;
  justify-content: space-between;
  font-size: 13px;
  color: var(--ink-mute);
  padding-top: 16px;
  border-top: 1px solid var(--rule);
}

/* Divider */
.slide.divider {
  padding: 56px 64px;
  border-left: 6px solid var(--accent);
  justify-content: center;
}
.part-label {
  font-size: 11px; font-weight: 600; letter-spacing: 0.2em;
  text-transform: uppercase; color: var(--ink-mute);
  margin-bottom: 14px;
}
.part-num {
  font-size: 140px;
  font-weight: 300;
  line-height: 1;
  color: var(--accent);
  letter-spacing: -0.03em;
  margin-bottom: 4px;
}
.divider-h2 {
  font-size: 42px;
  font-weight: 500;
  line-height: 1.1;
  color: var(--ink);
  letter-spacing: -0.02em;
  max-width: 22ch;
}
.divider-h2 em {
  font-style: italic;
  color: var(--accent);
  font-weight: 400;
}
.divider-sub {
  font-size: 22px;
  color: var(--ink-soft);
  line-height: 1.4;
  margin-top: 20px;
  max-width: 48ch;
  font-style: italic;
}
.divider-bar {
  width: 180px;
  height: 1px;
  background: var(--rule);
