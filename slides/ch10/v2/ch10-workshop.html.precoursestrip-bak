<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<title>Ch10 Pricing Workshop / workshop</title>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<style>

@import url('https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@400;600;700&display=swap');
:root {
  --accent: #DA7756;
  --accent-deep: #B8553A;
  --accent-tint: #FDF6F3;
  --ink: #1a1a1a;
  --ink-body: #333333;
  --ink-soft: #4A4A4A;
  --ink-mute: #7A7A7A;
  --ink-label: #5C5C5C;
  --rule: #E8E6E1;
  --source: #888888;
  --bg: #ffffff;
  --bg-soft: #f8f9fa;
  --font: 'Source Sans 3', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}
* { margin: 0; padding: 0; box-sizing: border-box; }
html, body {
  background: #0a0806;
  font-family: var(--font);
  color: var(--ink);
}
body {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px;
}
.deck {
  position: relative;
  width: 100vw;
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}
.slide {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(var(--scale, 1));
  width: 960px;
  height: 540px;
  background: var(--bg);
  padding: 28px 40px 48px 40px;
  overflow: hidden;
  box-shadow: 0 8px 32px -8px rgba(0,0,0,.35);
  display: none;
  flex-direction: column;
}
.slide.current { display: flex; }

@media (min-aspect-ratio: 16/9) {
  .slide { transform: translate(-50%, -50%) scale(calc((100vh - 48px) / 540)); }
}
@media (max-aspect-ratio: 16/9) {
  .slide { transform: translate(-50%, -50%) scale(calc((100vw - 48px) / 960)); }
}

.page {
  position: absolute;
  top: 22px;
  right: 40px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink-mute);
}
.eyebrow {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink-mute);
  margin-bottom: 10px;
}
.title {
  font-size: 28px;
  font-weight: 600;
  color: var(--ink);
  line-height: 1.22;
  letter-spacing: -0.01em;
  max-width: 880px;
}
.title em {
  font-style: normal;
  color: var(--accent);
}
.rule {
  width: 60px;
  height: 2px;
  background: var(--accent);
  margin-top: 14px;
  margin-bottom: 18px;
}

.head { flex-shrink: 0; }

.body-area {
  display: flex;
  flex: 1 1 auto;
  min-height: 0;
  gap: 28px;
  align-items: stretch;
  margin-top: 8px;
}
.slide.with-exhibit .body-area { flex-direction: row; }
.slide.no-exhibit .body-area { flex-direction: column; }
.slide.with-exhibit .exhibit {
  flex: 1.5 1 auto;
  min-width: 0;
  min-height: 0;
  background: var(--bg);
  border: 1px solid var(--rule);
  padding: 18px 20px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.slide.with-exhibit .exhibit svg {
  width: 100%;
  height: 100%;
  display: block;
  max-height: 100%;
}
.slide.with-exhibit .body-text {
  flex: 1 1 0;
  min-width: 220px;
  max-width: 320px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.slide.no-exhibit .body-text {
  flex: 1 1 auto;
}

.lede {
  font-size: 22px;
  line-height: 1.4;
  color: var(--ink-body);
  max-width: 720px;
}
.slide.with-exhibit .lede {
  font-size: 20px;
  line-height: 1.4;
}
.lede em { font-style: normal; color: var(--accent); }

.build {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 14px;
  max-width: 760px;
}
.build li {
  font-size: 20px;
  line-height: 1.4;
  color: var(--ink-body);
  padding-left: 28px;
  position: relative;
  opacity: 0.18;
  transition: opacity 220ms ease-out;
}
.build li::before {
  content: counter(rev, decimal);
  counter-increment: rev;
  position: absolute;
  left: 0;
  top: 4px;
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: var(--accent);
  color: #fff;
  font-size: 11px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}
.build { counter-reset: rev; }
.build li em { font-style: normal; color: var(--accent); }
.build li.shown { opacity: 1; }

.source {
  position: absolute;
  bottom: 14px;
  right: 20px;
  font-size: 11px;
  color: var(--source);
  letter-spacing: 0.02em;
  max-width: 700px;
  text-align: right;
}

/* Cover */
.slide.cover {
  padding: 56px 64px;
  border-top: 4px solid var(--accent);
  justify-content: space-between;
}
.course-tag { display: flex; align-items: center; gap: 12px; }
.course-tag .dot {
  width: 10px; height: 10px; border-radius: 50%; background: var(--accent);
}
.course-tag .label {
  font-size: 11px; font-weight: 600; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--ink-label);
}
.cover-stack { flex: 1; display: flex; flex-direction: column; justify-content: center; }
.cover-h1 {
  font-size: 54px;
  font-weight: 600;
  line-height: 1.08;
  letter-spacing: -0.02em;
  color: var(--ink);
  max-width: 17ch;
}
.cover-h1 em { font-style: italic; color: var(--accent); font-weight: 500; }
.cover-meta {
  font-size: 20px;
  color: var(--ink-soft);
  margin-top: 22px;
  max-width: 44ch;
  line-height: 1.5;
}
.cover-foot {
  display: flex;
  justify-content: space-between;
  font-size: 13px;
  color: var(--ink-mute);
  padding-top: 16px;
  border-top: 1px solid var(--rule);
}

/* Divider */
.slide.divider {
  padding: 56px 64px;
  border-left: 6px solid var(--accent);
  justify-content: center;
}
.part-label {
  font-size: 11px; font-weight: 600; letter-spacing: 0.2em;
  text-transform: uppercase; color: var(--ink-mute);
  margin-bottom: 14px;
}
.part-num {
  font-size: 140px;
  font-weight: 300;
  line-height: 1;
  color: var(--accent);
  letter-spacing: -0.03em;
  margin-bottom: 4px;
}
.divider-h2 {
  font-size: 42px;
  font-weight: 500;
  line-height: 1.1;
  color: var(--ink);
  letter-spacing: -0.02em;
  max-width: 22ch;
}
.divider-h2 em {
  font-style: italic;
  color: var(--accent);
  font-weight: 400;
}
.divider-sub {
  font-size: 22px;
  color: var(--ink-soft);
  line-height: 1.4;
  margin-top: 20px;
  max-width: 48ch;
  font-style: italic;
}
.divider-bar {
  width: 180px;
  height: 1px;
  background: var(--rule);
  margin-top: 24px;
}

/* Transition */
.slide.transition {
  padding: 64px;
  justify-content: center;
  align-items: flex-start;
}
.trans-stack {
  max-width: 720px;
}
.trans-eyebrow {
  font-size: 11px; font-weight: 600; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--accent);
  margin-bottom: 18px;
}
.trans-h2 {
  font-size: 32px;
  font-weight: 600;
  line-height: 1.25;
  color: var(--ink);
  letter-spacing: -0.01em;
}
.trans-h2 em { font-style: normal; color: var(--accent); }
.trans-sub {
  font-size: 20px;
  color: var(--ink-soft);
  margin-top: 18px;
  line-height: 1.5;
  font-style: italic;
}

/* Activity (workshop) */
.slide.activity {
  padding: 32px 40px 48px;
}
.activity-tag {
  display: inline-block;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--accent-deep);
  background: var(--accent-tint);
  padding: 5px 12px;
  margin-bottom: 14px;
}
.activity-prompts {
  margin-top: 24px;
  background: var(--bg-soft);
  border-left: 3px solid var(--accent);
  padding: 16px 22px;
}
.activity-prompts h4 {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--accent-deep);
  margin-bottom: 10px;
}
.activity-prompts ul {
  list-style: none;
  padding: 0;
}
.activity-prompts li {
  font-size: 18px;
  line-height: 1.4;
  color: var(--ink-body);
  padding-left: 18px;
  position: relative;
  margin-bottom: 6px;
}
.activity-prompts li::before {
  content: "";
  position: absolute;
  left: 0;
  top: 11px;
  width: 10px;
  height: 1px;
  background: var(--accent);
}

.exhibit.missing {
  background: var(--bg-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  font-style: italic;
  color: var(--ink-mute);
}

</style>
</head>
<body>
<main class="deck" data-deck="ch10-workshop">
<section class="slide cover" data-tier="essential">
  <div class="course-tag"><span class="dot"></span><span class="label">MKTG 4333 / Ch 10 Workshop</span></div>
  <div class="cover-stack">
    <h1 class="cover-h1">Workshop: <em>price a real brand with the chapter's machinery and an AI assistant.</em></h1>
    <p class="cover-meta">By the end of this session, every student has a written, defended price recommendation.</p>
  </div>
  <footer class="cover-foot">
    <span>MKTG 4333 / Principles of Marketing</span>
    <span>An AI-Integrated Approach</span>
  </footer>
</section>
<section class="slide k-claim no-exhibit" data-tier="essential" data-idx="1">
  <span class="page">02 / 15</span>
  <header class="head">
    <div class="eyebrow">Setup</div>
    <h1 class="title">Pick a real brand you buy or one you would actually launch.</h1>
    <div class="rule"></div>
  </header>
  <div class="body-area">
    
    <div class="body-text"><p class="lede">Greek-life co-branded drink, Etsy item, campus tutoring service, or a real consumer brand. Lock it in now.</p></div>
  </div>
  
</section>
<section class="slide activity" data-tier="essential">
  <span class="page">03 / 15</span>
  <div class="activity-tag">Activity 1 / 8 minutes</div>
  <h1 class="title">Activity 1: <em>Build the EVC walk for your brand.</em></h1>
  <div class="rule"></div>
  <p class="lede">Find the next-best alternative, write its price as the base, attach a dollar premium to each better attribute. 8 minutes.</p>
  <div class="activity-prompts"><h4>Discussion prompts</h4><ul><li>What is the alternative's price?</li><li>Name three attributes where you win. What dollar premium does each carry, and why?</li></ul></div>
</section>
<section class="slide activity" data-tier="essential">
  <span class="page">04 / 15</span>
  <div class="activity-tag">Activity 1 debrief</div>
  <h1 class="title">Debrief: <em>read three EVC walks out loud and ask the room to pick the most defensible.</em></h1>
  <div class="rule"></div>
  <p class="lede">Pull three volunteers. Strongest walk earns the closing price the room would actually pay.</p>
  <div class="activity-prompts"><h4>Discussion prompts</h4><ul><li>Which premium reads as the strongest? Which reads as the seller's wish?</li><li>Would you pay the closing price?</li></ul></div>
</section>
<section class="slide activity" data-tier="essential">
  <span class="page">05 / 15</span>
  <div class="activity-tag">Activity 2 / 10 minutes</div>
  <h1 class="title">Activity 2: <em>Run the four PSM questions on your partner.</em></h1>
  <div class="rule"></div>
  <p class="lede">Trade roles. Write down their four answers. Read them back. 10 minutes total.</p>
  <div class="activity-prompts"><h4>Discussion prompts</h4><ul><li>Where did your partner's 'too cheap' sit? Did that surprise you?</li><li>What is your acceptable band based on your partner's four numbers?</li></ul></div>
</section>
<section class="slide k-claim no-exhibit" data-tier="standard" data-idx="5">
  <span class="page">06 / 15</span>
  <header class="head">
    <div class="eyebrow">Activity 2 caveat</div>
    <h1 class="title">Common pitfall: <em>a sample of one is not a band. Your partner's four numbers are a candidate, not a study.</em></h1>
    <div class="rule"></div>
  </header>
  <div class="body-area">
    
    <div class="body-text"><p class="lede">A defensible PSM needs 200-400 respondents. Today's exercise teaches the question structure, not the band.</p></div>
  </div>
  
</section>
<section class="slide activity" data-tier="essential">
  <span class="page">07 / 15</span>
  <div class="activity-tag">Activity 3 / 8 minutes</div>
  <h1 class="title">Activity 3: <em>Design a three-option lineup that steers buyers toward your target option.</em></h1>
  <div class="rule"></div>
  <p class="lede">Either a decoy (dominated on every attribute) or a compromise (target sits in the defensible middle). 8 minutes.</p>
  <div class="activity-prompts"><h4>Discussion prompts</h4><ul><li>Which lineup did you build, decoy or compromise? Why does it fit your product?</li><li>What share split do you predict? Why?</li></ul></div>
</section>
<section class="slide activity" data-tier="depth">
  <span class="page">08 / 15</span>
  <div class="activity-tag">Activity 3 debrief</div>
  <h1 class="title">Debrief: <em>when does a decoy backfire?</em></h1>
  <div class="rule"></div>
  <p class="lede">Decoys break when buyers comparison-shop online, when the decoy is too obvious, or when the difference is too small.</p>
  <div class="activity-prompts"><h4>Discussion prompts</h4><ul><li>Have you ever caught a brand using a decoy on you? How did that change your read of them?</li></ul></div>
</section>
<section class="slide activity" data-tier="essential">
  <span class="page">09 / 15</span>
  <div class="activity-tag">Activity 4 / 10 minutes</div>
  <h1 class="title">Activity 4: <em>Run the sharp competitor audit on your brand using Claude or ChatGPT.</em></h1>
  <div class="rule"></div>
  <p class="lede">One prompt, web search on, named levers. 10 minutes including the comparison with the vague version.</p>
  <div class="activity-prompts"><h4>Discussion prompts</h4><ul><li>Which levers did the model name? Did it miss any obvious ones?</li><li>What is the gap between the two responses? In your own words.</li></ul></div>
</section>
<section class="slide k-claim no-exhibit" data-tier="essential" data-idx="9">
  <span class="page">10 / 15</span>
  <header class="head">
    <div class="eyebrow">Activity 4 prompt</div>
    <h1 class="title">The sharp prompt: <em>audit, three competitors, named levers, current shelf prices.</em></h1>
    <div class="rule"></div>
  </header>
  <div class="body-area">
    
    <div class="body-text"><p class="lede">Audit my [brand] at [price] against [three competitors]. Name two or three levers the recommendation rests on. Use current shelf prices.</p></div>
  </div>
  
</section>
<section class="slide activity" data-tier="standard">
  <span class="page">11 / 15</span>
  <div class="activity-tag">Activity 4 debrief</div>
  <h1 class="title">Debrief: what did the model get right, and <em>what would you still verify?</em></h1>
  <div class="rule"></div>
  <p class="lede">Three things the model nailed. Two things you would not trust without checking.</p>
  <div class="activity-prompts"><h4>Discussion prompts</h4><ul><li>Did the model name a lever you would not have caught yourself?</li><li>What single number from the response would you double-check?</li></ul></div>
</section>
<section class="slide activity" data-tier="essential">
  <span class="page">12 / 15</span>
  <div class="activity-tag">Activity 5 / 6 minutes</div>
  <h1 class="title">Activity 5: <em>Run your price through the fairness checklist before you ship.</em></h1>
  <div class="rule"></div>
  <p class="lede">Is there a cost story? Is there an off-peak or lower option? Was the change published before it took effect? 6 minutes.</p>
  <div class="activity-prompts"><h4>Discussion prompts</h4><ul><li>Does your price fail any of the three? Which one is hardest to satisfy?</li><li>If you were a regulator, would you investigate your own brand?</li></ul></div>
</section>
<section class="slide activity" data-tier="essential">
  <span class="page">13 / 15</span>
  <div class="activity-tag">Deliverable</div>
  <h1 class="title">Final 8 minutes: <em>write your one-page recommendation.</em></h1>
  <div class="rule"></div>
  <p class="lede">Brand, buyer segment, EVC walk, PSM band, lineup design, AI audit verdict, fairness check. One page.</p>
  <div class="activity-prompts"><h4>Discussion prompts</h4><ul><li>What is the one sentence you would say to your CEO to defend this price?</li></ul></div>
</section>
<section class="slide activity" data-tier="standard">
  <span class="page">14 / 15</span>
  <div class="activity-tag">Cross-review</div>
  <h1 class="title">Share: <em>trade one-pagers with your partner and red-team each other.</em></h1>
  <div class="rule"></div>
  <p class="lede">Find the weakest premium in the EVC. Find the lever the audit missed. 5 minutes total.</p>
  <div class="activity-prompts"><h4>Discussion prompts</h4><ul><li>Which premium in your partner's EVC needs the most defense?</li><li>What lever did your partner's audit miss?</li></ul></div>
</section>
<section class="slide k-closing no-exhibit" data-tier="essential" data-idx="14">
  <span class="page">15 / 15</span>
  <header class="head">
    <div class="eyebrow">Close</div>
    <h1 class="title">You have a defensible price now, with the levers named.</h1>
    <div class="rule"></div>
  </header>
  <div class="body-area">
    
    <div class="body-text"><p class="lede">Take the one-pager home. Run the same procedure on the next product you buy.</p></div>
  </div>
  
</section>
</main>

<script>
(function() {
  const slides = document.querySelectorAll('.slide');
  let cur = 0;
  function show(i) {
    slides.forEach((s, idx) => s.classList.toggle('current', idx === i));
    cur = i;
    location.hash = '#' + (i + 1);
    // reveal build_reveal frames
    const cur_s = slides[i];
    if (cur_s) {
      const frames = cur_s.querySelectorAll('.frame');
      frames.forEach((f, fi) => f.classList.toggle('shown', fi === 0));
      cur_s.dataset.frameIdx = '0';
    }
  }
  function advanceFrameOrSlide(dir) {
    const s = slides[cur];
    const frames = s ? s.querySelectorAll('.frame') : [];
    const idxAttr = parseInt((s && s.dataset.frameIdx) || '0', 10);
    if (dir > 0 && frames.length && idxAttr < frames.length - 1) {
      const ni = idxAttr + 1;
      s.dataset.frameIdx = String(ni);
      frames.forEach((f, fi) => f.classList.toggle('shown', fi <= ni));
      return;
    }
    if (dir < 0 && frames.length && idxAttr > 0) {
      const ni = idxAttr - 1;
      s.dataset.frameIdx = String(ni);
      frames.forEach((f, fi) => f.classList.toggle('shown', fi <= ni));
      return;
    }
    const next = Math.max(0, Math.min(slides.length - 1, cur + dir));
    show(next);
  }
  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowRight' || e.key === ' ' || e.key === 'PageDown' || e.key === 'j' || e.key === 'l') {
      advanceFrameOrSlide(1); e.preventDefault();
    } else if (e.key === 'ArrowLeft' || e.key === 'PageUp' || e.key === 'k' || e.key === 'h') {
      advanceFrameOrSlide(-1); e.preventDefault();
    } else if (e.key === 'Home') {
      show(0); e.preventDefault();
    } else if (e.key === 'End') {
      show(slides.length - 1); e.preventDefault();
    }
  });
  document.addEventListener('click', (e) => {
    if (e.target.closest('a, button, input, select, textarea')) return;
    const rect = document.documentElement.getBoundingClientRect();
    const x = (e.clientX - rect.left) / rect.width;
    if (x < 0.3) advanceFrameOrSlide(-1);
    else if (x > 0.7) advanceFrameOrSlide(1);
  });
  // initial slide from hash
  const hash = parseInt(location.hash.slice(1), 10);
  if (!isNaN(hash) && hash >= 1 && hash <= slides.length) {
    show(hash - 1);
  } else {
    show(0);
  }
})();
</script>

</body>
