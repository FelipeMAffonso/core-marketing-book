<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<title>MKTG 4333 · Chapter 10 · Pricing deck</title>
<style>
  :root{
    --bg:#f5f2ec; --ink:#1a1a1a; --ink-soft:#4A4A4A; --ink-mute:#7A7A7A;
    --rule:#E8E6E1; --accent:#DA7756; --accent-tint:#FDF6F3;
    --font:'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  }
  *{ margin:0; padding:0; box-sizing:border-box; }
  html,body{ background:var(--bg); font-family:var(--font); color:var(--ink); }
  body{ padding:64px 72px 96px; }
  header{
    display:flex; justify-content:space-between; align-items:flex-end;
    border-bottom:1px solid var(--rule); padding-bottom:20px; margin-bottom:36px;
  }
  header .dot{ display:inline-block; width:10px; height:10px; background:var(--accent); border-radius:50%; margin-right:10px; vertical-align:middle; }
  header h1{ font-size:32px; font-weight:600; letter-spacing:-0.01em; }
  header h1 em{ font-style:italic; color:var(--accent); font-weight:500; }
  header .meta{
    font-size:11px; letter-spacing:0.12em; text-transform:uppercase;
    color:var(--ink-mute); font-weight:600;
  }
  .intro{
    max-width:70ch; font-size:18px; line-height:1.55; color:var(--ink-soft);
    margin-bottom:44px;
  }
  .intro a{ color:var(--accent); text-decoration:none; border-bottom:1px solid var(--accent); }
  .grid{
    display:grid; grid-template-columns: repeat(auto-fill, minmax(420px, 1fr));
    gap:28px;
  }
  .card{
    background:#fff; border:1px solid var(--rule);
    display:flex; flex-direction:column; overflow:hidden;
    transition: transform .2s, box-shadow .2s;
  }
  .card:hover{ transform:translateY(-2px); box-shadow: 0 8px 24px -10px rgba(0,0,0,.15); }
  .card .frame{
    position:relative; aspect-ratio: 16 / 9; overflow:hidden; background:#ffffff;
    border-bottom:1px solid var(--rule);
  }
  .card .frame .scaler{
    position:absolute; top:0; left:0;
    width:960px; height:540px;
    transform-origin: top left;
  }
  .card .frame iframe{
    width:960px; height:540px; border:0; display:block; pointer-events:none;
    background:#ffffff;
  }
  .card .info{ padding:16px 22px; display:flex; justify-content:space-between; align-items:baseline; gap:12px; }
  .card .info h3{ font-size:16px; font-weight:600; line-height:1.3; }
  .card .info .n{
    font-size:11px; font-weight:600; letter-spacing:0.14em; color:var(--ink-mute);
    text-transform:uppercase; white-space:nowrap;
  }
  .card .info .tmpl{ display:block; font-size:12px; color:var(--ink-soft); margin-top:3px; font-style:italic; }
  .card a.open{
    display:block; text-align:right; font-size:11px; letter-spacing:0.12em;
    text-transform:uppercase; color:var(--accent); font-weight:600;
    padding:0 22px 16px; text-decoration:none;
  }
  footer{
    margin-top:64px; padding-top:20px; border-top:1px solid var(--rule);
    font-size:13px; color:var(--ink-mute); display:flex; justify-content:space-between;
  }
</style>
</head>
<body>
  <header>
    <h1><span class="dot"></span>Chapter 10 · <em>Pricing</em>.</h1>
    <span class="meta">MKTG 4333 · 20 slides · 960 × 540</span>
  </header>

  <p class="intro">
    A teaching deck on pricing, built on the coral design system. One claim per slide, white backgrounds,
    one coral element per slide, Segoe UI throughout. It pairs with the Chapter 10 lecture video and runs the
    same arc: why a 1% price move beats a 1% volume move, the value stick, the four approaches (cost, competitor,
    value, customer-determined), breakeven and the markup-versus-margin trap, the EVC walk, willingness to pay
    and the Van Westendorp band, the decoy effect, the fairness ceiling on dynamic pricing, and the three brand
    anchors (Costco, Patagonia, Liquid Death). Read the system rules in
    <a href="../DESIGN-SYSTEM.md">DESIGN-SYSTEM.md</a> and
    <a href="../CHART-PRINCIPLES.md">CHART-PRINCIPLES.md</a>.
  </p>

  <div class="grid" id="grid"></div>

<script>
(() => {
  const slides = [
    ["01-title.html",            "01", "Pricing, the one decision that brings in revenue", "Title / cover"],
    ["02-divider-leverage.html", "02", "A 1% price move is worth more than a 1% volume move", "Section divider"],
    ["03-leverage.html",         "03", "At a 3% margin, a 1% price move lifts profit about 33%", "Comparison bars"],
    ["04-value-stick.html",      "04", "The price lives between cost and willingness to pay", "Exhibit · value stick"],
    ["05-epipen.html",           "05", "The EpiPen climbed $100 to $608 and broke at the fairness ceiling", "Trend line"],
    ["06-divider-approaches.html","06","Cost is the floor, the competitor is the frame, value is the ceiling", "Section divider"],
    ["07-price-ladder.html",     "07", "A firm works up from cost to competitor to value", "Exhibit · chapter price ladder"],
    ["08-breakeven.html",        "08", "A $5 drink that costs $1.50 breaks even at 2,000 cups", "Exhibit · chapter breakeven"],
    ["09-markup-margin.html",    "09", "A 50% markup is only a 33% margin on the same unit", "Two-column"],
    ["10-evc-caterpillar.html",  "10", "Caterpillar builds $90K to a $110K value ceiling, closes at $100K", "Exhibit · EVC waterfall"],
    ["11-divider-wtp.html",      "11", "Willingness to pay varies from one buyer to the next", "Section divider"],
    ["12-elasticity.html",       "12", "A 10% move cost 15% of volume, so the tumbler was elastic at -1.5", "Relationship"],
    ["13-van-westendorp.html",   "13", "Four questions cross to bound an acceptable price band", "Exhibit · chapter PSM"],
    ["14-divider-psych.html",    "14", "Buyers read prices against a reference point", "Section divider"],
    ["15-decoy.html",            "15", "A $125 option nobody picks lifts the bundle from 68% to 84%", "Comparison bars · chapter decoy"],
    ["16-divider-fairness.html", "16", "Buyers reject efficient transactions they read as unfair", "Section divider"],
    ["17-zoo-vs-wendys.html",    "17", "Wendy's reversed in twelve days; the Zoo's grid held", "Two-column"],
    ["18-fairness-quote.html",   "18", "The same dollar reads as fair after a cost rise, gouging after a spike", "Pull quote"],
    ["19-three-brands.html",     "19", "Each brand commits to one anchor; Liquid Death charges 5-8x", "KPI row"],
    ["20-closing.html",          "20", "Run the three-question read on a brand you actually buy", "Closing / takeaways"]
  ];
  const grid = document.getElementById('grid');
  slides.forEach(([href, n, claim, tmpl]) => {
    const card = document.createElement('article');
    card.className = 'card';
    card.innerHTML =
      '<div class="frame"><div class="scaler"><iframe src="' + href + '?thumb=1" title="' + claim + '"></iframe></div></div>' +
      '<div class="info"><div><h3>' + claim + '</h3><span class="tmpl">' + tmpl + '</span></div><span class="n">' + n + '</span></div>' +
      '<a class="open" href="' + href + '" target="_blank">Open &rarr;</a>';
    grid.appendChild(card);
  });

  function fitCards(){
    document.querySelectorAll('.card .frame').forEach(frame => {
      const scaler = frame.querySelector('.scaler');
      if (!scaler) return;
      const w = frame.clientWidth;
      const s = w / 960;
      scaler.style.transform = 'scale(' + s + ')';
      scaler.style.width  = '960px';
      scaler.style.height = '540px';
      frame.style.height = (540 * s) + 'px';
    });
  }
  document.querySelectorAll('iframe').forEach(f => {
    f.addEventListener('load', () => {
      try { f.contentDocument.documentElement.classList.add('is-thumb'); } catch(_){}
    });
  });
  window.addEventListener('resize', fitCards);
  window.addEventListener('load', fitCards);
  fitCards();
})();
</script>

  <footer>
    <span>MKTG 4333 · Prof. Felipe M. Affonso · Spears School of Business</span>
    <span>White bg · Segoe UI · one coral accent · pairs with the Ch 10 video</span>
  </footer>
</body>
</html>
